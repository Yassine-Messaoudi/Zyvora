{
  "name": "zyvory-digital-store",
  "version": "1.0.0",
  "description": "Zyvory - Full-stack digital products marketplace with admin dashboard, image uploads, and crypto checkout.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "client": "vite --host 127.0.0.1 --port 5173",
    "server": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "scrape:lusive": "node scripts/scrape-lusive-products.js",
    "import:lusive": "node scripts/scrape-lusive-products.js --apply",
    "seed:products": "node scripts/seed-imported-products.js",
    "test": "node --test server/payments.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^2.5.2",
    "lucide-react": "^1.14.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "simple-icons": "^16.19.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.21"
  }
}
