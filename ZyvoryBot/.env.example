DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Optional, but recommended. If set, slash commands register instantly to this guild.
GUILD_ID=your_discord_server_id_here

# Optional ticket routing.
TICKET_CATEGORY_ID=
STAFF_ROLE_ID=
LOG_CHANNEL_ID=

# Brand links.
SUPPORT_URL=https://discord.gg/Zhd6unzQGm

# Optional. Set to true only after enabling Message Content Intent in Discord Developer Portal.
ENABLE_MESSAGE_CONTENT_INTENT=false

# Optional. Set true if your host should not update slash commands on boot.
SKIP_COMMAND_REGISTRATION=false

# Store API integration — enables automatic order lookup in tickets.
# STORE_API_URL should point to your Zyvora store backend (e.g. http://localhost:8787)
STORE_API_URL=
# BOT_API_KEY must match the BOT_API_KEY set in your store's .env
BOT_API_KEY=
